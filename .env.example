# ── Slide backend configuration ──────────────────────────────────────────────
# Copy to `.env` for local dev. Never commit `.env`.

# Postgres (docker-compose default)
DATABASE_URL=postgres://slide:slide@localhost:5432/slide

# Redis (docker-compose default) — OTP TTL + presence
REDIS_URL=redis://localhost:6379

# JWT signing secret (HS256). Generate: openssl rand -hex 32
JWT_SECRET=dev-only-insecure-secret-change-me-0000000000000000000000000000

# Access token lifetime (seconds). Default 15m.
ACCESS_TOKEN_TTL_SECS=900
# Refresh token lifetime (seconds). Default 60d.
REFRESH_TOKEN_TTL_SECS=5184000

# SFU join token lifetime (seconds). Default 5m.
JOIN_TOKEN_TTL_SECS=300

# OTP config
OTP_TTL_SECS=300
OTP_MAX_ATTEMPTS=5
# Server-side pepper for hashing OTP codes. openssl rand -hex 32
OTP_PEPPER=dev-only-otp-pepper-change-me-000000000000000000000000000000

# SMS provider: "console" (dev, prints code to logs) | "twilio"
SMS_PROVIDER=console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# SFU
# Public base URL the control plane hands clients for the media socket.
SFU_PUBLIC_URL=ws://localhost:9000
# Shared secret the control plane uses to mint SFU join tokens the SFU trusts.
SFU_JWT_SECRET=dev-only-sfu-secret-change-me-00000000000000000000000000000000

# TURN (coturn) — time-limited REST credentials
TURN_URIS=turn:localhost:3478?transport=udp,turn:localhost:3478?transport=tcp
TURN_SHARED_SECRET=dev-only-turn-secret-change-me-0000000000000000000000000000
TURN_CRED_TTL_SECS=600

# Object storage for avatars (S3-compatible: AWS S3, Supabase Storage, R2)
S3_BUCKET=slide-avatars
S3_REGION=us-east-1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# Server bind
API_BIND=0.0.0.0:8080
SFU_BIND=0.0.0.0:9000
SFU_NODE_ID=sfu-local-1

RUST_LOG=info,slide_api=debug,slide_sfu=debug,tower_http=debug
