# ── Slide backend configuration ──────────────────────────────────────────────
# Copy to `.env` for local dev. Never commit `.env`.

# Postgres (docker-compose default)
DATABASE_URL=postgres://slide:slide@localhost:5432/slide

# Redis (docker-compose default) — OTP TTL + presence
REDIS_URL=redis://localhost:6379

# JWT signing secret (HS256). Generate: openssl rand -hex 32
JWT_SECRET=dev-only-insecure-secret-change-me-0000000000000000000000000000

# Access token lifetime (seconds). Default 15m.
ACCESS_TOKEN_TTL_SECS=900
# Refresh token lifetime (seconds). Default 60d.
REFRESH_TOKEN_TTL_SECS=5184000

# SFU join token lifetime (seconds). Default 5m.
JOIN_TOKEN_TTL_SECS=300

# OTP config
OTP_TTL_SECS=300
OTP_MAX_ATTEMPTS=5
# Server-side pepper for hashing OTP codes. openssl rand -hex 32
OTP_PEPPER=dev-only-otp-pepper-change-me-000000000000000000000000000000

# SMS provider: "console" (dev, prints code to logs) | "twilio"
SMS_PROVIDER=console
# Only set true for local/CI smoke tests that need /auth/request-otp to return
# devCode. The API refuses to start if this is true with a real SMS provider.
EXPOSE_DEV_OTP=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# SFU
# Public base URL the control plane hands clients for the media socket.
SFU_PUBLIC_URL=ws://localhost:9000
# Shared secret the control plane uses to mint SFU join tokens the SFU trusts.
SFU_JWT_SECRET=dev-only-sfu-secret-change-me-00000000000000000000000000000000

# TURN (coturn) — time-limited REST credentials
TURN_URIS=turn:localhost:3478?transport=udp,turn:localhost:3478?transport=tcp
TURN_SHARED_SECRET=dev-only-turn-secret-change-me-0000000000000000000000000000
TURN_CRED_TTL_SECS=600

# Object storage for avatars (S3-compatible: AWS S3, Supabase Storage, R2)
S3_BUCKET=slide-avatars
S3_REGION=us-east-1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# Server bind
API_BIND=0.0.0.0:8080
SFU_BIND=0.0.0.0:9000
SFU_NODE_ID=sfu-local-1

RUST_LOG=info,slide_api=debug,slide_sfu=debug,tower_http=debug

# ── Push notifications ───────────────────────────────────────────────────────
# All optional. Leave a provider's vars empty to disable it (no-op at runtime).
# When an incoming call (or an offline knock) can't be delivered over the
# WebSocket, the server falls back to these to ring a closed/backgrounded app.
# Register tokens via POST /v1/push/register {pushToken, kind, p256dh?, auth?}.

# APNs VoIP (iOS). APNS_KEY_P8 may be the .p8 PEM contents OR a path to the file.
# APNS_TOPIC is the bundle id + ".voip". APNS_ENV: sandbox | prod.
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY_P8=
APNS_TOPIC=app.exla.slide.voip
APNS_ENV=prod

# FCM (Android), HTTP v1. Service-account JSON inline OR a path to the file.
# FCM_PROJECT_ID overrides the project_id inside the JSON if set.
FCM_SERVICE_ACCOUNT_JSON=
FCM_PROJECT_ID=

# Web Push (browser), VAPID. Generate your own for production; the example pair
# below is a working dev keypair. NEVER commit a real private key.
VAPID_PUBLIC_KEY=BMPf99ro_pKbqPSFLkGNYcM_lCWTS85ge4rNlvhdvn_bVqW-FI1Buk04OYPsnj3OJWhyJJ-j73X4E9yDq3JxLX4
VAPID_PRIVATE_KEY=hd5ZFqtICUQD7DJN1gWu5fw0xs4AvtV_qAxY1m2dkik
VAPID_SUBJECT=mailto:ops@exla.ai
