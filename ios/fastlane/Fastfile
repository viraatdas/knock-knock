# fastlane Fastfile — Slide iOS
#
# The App Store pipeline, CLI-driven. Auth uses an App Store Connect API key
# (no 2FA, CI-friendly) read from the environment:
#   ASC_KEY_ID, ASC_ISSUER_ID, ASC_KEY_PATH  (path to the .p8)
# plus APP_IDENTIFIER (default app.slide) and APPLE_TEAM_ID for signing.
#
# Lanes:
#   build_sim   — unsigned Simulator build (no account needed; CI smoke).
#   archive     — signed .ipa via gym (needs Team ID + signing).
#   beta        — archive + upload to TestFlight.
#   release     — archive + upload to App Store + submit for review.
#   bootstrap   — create the App Store Connect app record (idempotent).
#
# The /app-store-deploy skill wraps these and handles project generation,
# version bumping, and the one-time API-key check.

default_platform(:ios)

APP_ID   = ENV["APP_IDENTIFIER"] || "app.slide"
SCHEME   = "Slide"
PROJECT  = "Slide.xcodeproj"

def asc_api_key
  # Returns an App Store Connect API token from env, or nil if not configured.
  return nil unless ENV["ASC_KEY_ID"] && ENV["ASC_ISSUER_ID"] && ENV["ASC_KEY_PATH"]
  app_store_connect_api_key(
    key_id: ENV["ASC_KEY_ID"],
    issuer_id: ENV["ASC_ISSUER_ID"],
    key_filepath: ENV["ASC_KEY_PATH"],
    in_house: false,
  )
end

platform :ios do
  before_all do
    # Always (re)generate the Xcode project from project.yml so the build is
    # reproducible from source.
    sh("cd .. && xcodegen generate")
  end

  desc "Unsigned Simulator build — verifies the app compiles (no account needed)."
  lane :build_sim do
    xcodebuild(
      scheme: SCHEME,
      project: PROJECT,
      configuration: "Debug",
      sdk: "iphonesimulator",
      destination: "generic/platform=iOS Simulator",
      xcargs: "CODE_SIGNING_ALLOWED=NO -skipMacroValidation",
    )
    UI.success("Simulator build succeeded.")
  end

  desc "Create the App Store Connect app record (idempotent)."
  lane :bootstrap do
    key = asc_api_key
    UI.user_error!("ASC API key not configured — see the app-store-deploy skill") unless key
    produce(
      api_key: key,
      app_identifier: APP_ID,
      app_name: "Slide",
      language: "en-US",
      app_version: "1.0.0",
      sku: "slide-#{APP_ID}",
      team_id: ENV["APPLE_TEAM_ID"],
    )
  end

  desc "Signed archive (.ipa) via gym."
  lane :archive do
    key = asc_api_key
    increment_build_number_if_possible
    gym(
      scheme: SCHEME,
      project: PROJECT,
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      output_name: "Slide.ipa",
      xcargs: "-skipMacroValidation DEVELOPMENT_TEAM=#{ENV['APPLE_TEAM_ID']} CODE_SIGN_STYLE=Automatic CODE_SIGNING_ALLOWED=YES CODE_SIGNING_REQUIRED=YES TARGETED_DEVICE_FAMILY=1",
    )
  end

  desc "Build + upload to TestFlight."
  lane :beta do
    key = asc_api_key
    UI.user_error!("ASC API key not configured — see the app-store-deploy skill") unless key
    archive
    upload_to_testflight(
      api_key: key,
      app_identifier: APP_ID,
      skip_waiting_for_build_processing: true,
    )
  end

  desc "Build + upload to App Store + submit for review."
  lane :release do
    key = asc_api_key
    UI.user_error!("ASC API key not configured — see the app-store-deploy skill") unless key
    archive
    upload_to_app_store(
      api_key: key,
      app_identifier: APP_ID,
      skip_screenshots: false,
      skip_metadata: false,
      submit_for_review: true,
      automatic_release: true,
      precheck_include_in_app_purchases: false,
      force: true,
      submission_information: { add_id_info_uses_idfa: false },
    )
  end

  # Bump build number from the latest TestFlight build when an API key exists;
  # otherwise leave it (first upload).
  def increment_build_number_if_possible
    key = asc_api_key
    return unless key
    begin
      latest = latest_testflight_build_number(api_key: key, app_identifier: APP_ID)
      increment_build_number(xcodeproj: PROJECT, build_number: (latest + 1).to_s)
    rescue => e
      UI.message("No prior TestFlight build (#{e.message}); keeping current build number.")
    end
  end

  desc "Submit the already-uploaded build for App Store review (waits for processing)."
  lane :submit_review do
    key = asc_api_key
    UI.user_error!("ASC API key not configured") unless key
    upload_to_app_store(
      api_key: key,
      app_identifier: APP_ID,
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: false,
      submit_for_review: true,
      automatic_release: true,
      force: true,
      precheck_include_in_app_purchases: false,
      submission_information: { add_id_info_uses_idfa: false, export_compliance_uses_encryption: false },
    )
  end

  desc "Provision TestFlight internal testing for the latest build (installable today)."
  lane :tf_internal do
    require "spaceship"
    token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV["ASC_KEY_ID"], issuer_id: ENV["ASC_ISSUER_ID"], filepath: ENV["ASC_KEY_PATH"]
    )
    Spaceship::ConnectAPI.token = token

    app = Spaceship::ConnectAPI::App.find(APP_ID)
    UI.user_error!("App #{APP_ID} not found") unless app
    UI.message("App: #{app.name} (#{app.id})")

    build = Spaceship::ConnectAPI::Build.all(app_id: app.id, sort: "-version", limit: 1).first
    UI.user_error!("No build found on App Store Connect") unless build
    UI.success("Latest build: #{build.app_version} (#{build.version}) state=#{build.processing_state}")

    # Clear export compliance (Info.plist declares ITSAppUsesNonExemptEncryption=NO)
    begin
      build.update(attributes: { usesNonExemptEncryption: false })
      UI.success("Export compliance cleared (usesNonExemptEncryption=false)")
    rescue => e
      UI.important("Compliance update note: #{e.message}")
    end

    UI.success("Internal testing: account-holder Apple ID can install build #{build.version} from the TestFlight app.")
  end

  # Helper: connect spaceship with the API key.
  def asc_connect
    require "spaceship"
    token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV["ASC_KEY_ID"], issuer_id: ENV["ASC_ISSUER_ID"], filepath: ENV["ASC_KEY_PATH"]
    )
    Spaceship::ConnectAPI.token = token
    Spaceship::ConnectAPI::App.find(APP_ID)
  end

  desc "Fill every App Store listing field that the API allows; report what remains."
  lane :asc_fill do
    app = asc_connect
    UI.user_error!("App #{APP_ID} not found") unless app
    UI.header("App: #{app.name} (#{app.id})")
    done = []
    todo = []

    info = app.fetch_edit_app_info
    version = app.get_edit_app_store_version

    # 1) Categories (Social Networking primary; Utilities secondary)
    begin
      info.update_categories(category_id_map: {
        primary_category_id: "SOCIAL_NETWORKING",
        secondary_category_id: "UTILITIES",
      })
      done << "categories: Social Networking / Utilities"
    rescue => e
      todo << "categories (#{e.message[0,100]})"
    end

    # 2) Content rights declaration (we own/are licensed for all content)
    begin
      if app.content_rights_declaration == "DOES_NOT_USE_THIRD_PARTY_CONTENT"
        done << "content rights: already set"
      else
        app.update(attributes: { contentRightsDeclaration: "DOES_NOT_USE_THIRD_PARTY_CONTENT" })
        done << "content rights: no third-party content"
      end
    rescue => e
      todo << "content rights (#{e.message[0,100]})"
    end

    # 3) Age rating — declare everything none/false (utility video calling → 4+)
    begin
      decl = info.fetch_age_rating_declaration
      if decl
        attrs = {
          alcoholTobaccoOrDrugUseOrReferences: "NONE",
          contests: "NONE",
          gamblingSimulated: "NONE",
          medicalOrTreatmentInformation: "NONE",
          profanityOrCrudeHumor: "NONE",
          sexualContentGraphicAndNudity: "NONE",
          sexualContentOrNudity: "NONE",
          horrorOrFearThemes: "NONE",
          matureOrSuggestiveThemes: "NONE",
          violenceCartoonOrFantasy: "NONE",
          violenceRealistic: "NONE",
          violenceRealisticProlongedGraphicOrSadistic: "NONE",
          gunsOrOtherWeapons: false,
          healthOrWellnessTopics: false,
          lootBox: false,
          gambling: false,
          unrestrictedWebAccess: false,
          messagingAndChat: false,
          userGeneratedContent: false,
          advertising: false,
          parentalControls: false,
          ageAssurance: false,
          kidsAgeBand: nil,
        }
        decl.update(attributes: attrs)
        done << "age rating: all NONE (4+)"
      else
        todo << "age rating (no declaration object)"
      end
    rescue => e
      todo << "age rating (#{e.message[0,140]})"
    end

    # 4) Copyright + release type on the version
    begin
      version.update(attributes: { copyright: "2026 Viraat Das", releaseType: "AFTER_APPROVAL" })
      done << "copyright + auto-release on approval"
    rescue => e
      todo << "copyright (#{e.message[0,100]})"
    end

    UI.header("DONE (#{done.size})"); done.each { |d| UI.success("  ✔ #{d}") }
    UI.header("STILL TODO (#{todo.size})"); todo.each { |t| UI.important("  • #{t}") }
  end

  desc "Introspect spaceship API surface for app/version/appinfo."
  lane :asc_probe do
    app = asc_connect
    UI.message "APP methods: " + (app.methods - Object.instance_methods).sort.join(", ")
    begin
      infos = app.get_app_infos
      UI.message "APP_INFOS count=#{infos.size}"
      ai = infos.first
      UI.message "APPINFO state=#{ai.app_store_state rescue '?'} methods: " + (ai.methods - Object.instance_methods).sort.join(", ")
      UI.message "APPINFO primary=#{ai.primary_category&.id rescue '?'} secondary=#{ai.secondary_category&.id rescue '?'}"
    rescue => e
      UI.error "appinfo: #{e.class} #{e.message[0,140]}"
    end
    begin
      ai = app.fetch_edit_app_info
      UI.message "EDIT_APPINFO state=#{ai&.app_store_state rescue '?'} methods: " + (ai.methods - Object.instance_methods).sort.join(", ")
      UI.message "EDIT_APPINFO primary=#{ai.primary_category&.id rescue '?'} secondary=#{ai.secondary_category&.id rescue '?'}"
      adecl = ai.fetch_age_rating_declaration rescue nil
      UI.message "APPINFO age_decl present=#{!adecl.nil?} id=#{adecl&.id}"
      UI.message "APPINFO age_decl methods: " + ((adecl.methods - Object.instance_methods).sort.join(", ")) if adecl
    rescue => e
      UI.error "appinfo2: #{e.class} #{e.message[0,140]}"
    end
    begin
      v = app.get_edit_app_store_version
      UI.message "VERSION #{v&.version_string} state=#{v&.app_store_state}"
    rescue => e
      UI.error "version: #{e.class} #{e.message[0,140]}"
    end
  end

  # Raw App Store Connect REST call using spaceship's JWT. Bypasses broken helpers.
  def asc_raw(method, path, body = nil)
    require "net/http"; require "json"; require "uri"
    tok = Spaceship::ConnectAPI.token
    jwt = tok.text  # current signed JWT
    uri = URI("https://api.appstoreconnect.apple.com/#{path}")
    klass = { get: Net::HTTP::Get, post: Net::HTTP::Post, patch: Net::HTTP::Patch,
              delete: Net::HTTP::Delete }[method]
    req = klass.new(uri)
    req["Authorization"] = "Bearer #{jwt}"
    req["Content-Type"] = "application/json"
    req.body = body.to_json if body
    http = Net::HTTP.new(uri.host, uri.port); http.use_ssl = true
    res = http.request(req)
    parsed = (JSON.parse(res.body) rescue res.body)
    [res.code.to_i, parsed]
  end

  desc "Delete the dangling empty review submission (the 'No Items' one)."
  lane :asc_clean_review do
    app = asc_connect
    code, body = asc_raw(:get, "v1/apps/#{app.id}/reviewSubmissions?limit=50")
    subs = body["data"] || []
    UI.message "found #{subs.size} review submission(s)"
    subs.each do |s|
      st = s.dig("attributes", "state")
      UI.message "  #{s['id']} state=#{st}"
      # Only nuke ones that are not actually in/awaiting review
      if %w[READY_FOR_REVIEW COMPLETE CANCELING UNRESOLVED_ISSUES].include?(st)
        dc, dr = asc_raw(:delete, "v1/reviewSubmissions/#{s['id']}")
        if (200..299).include?(dc)
          UI.success "  deleted #{s['id']} (#{dc})"
        else
          # Some states need a cancel PATCH instead of delete
          pc, pr = asc_raw(:patch, "v1/reviewSubmissions/#{s['id']}",
            { data: { type: "reviewSubmissions", id: s["id"], attributes: { canceled: true } } })
          UI.message "  delete #{dc}; cancel PATCH -> #{pc}: #{pr.inspect[0,160]}"
        end
      end
    end
  end

  desc "Set Free pricing via the modern appPriceSchedule REST endpoint."
  lane :asc_price_free do
    app = asc_connect
    # 1) Find the USA $0 price point for this app
    code, pp = asc_raw(:get, "v1/apps/#{app.id}/appPricePoints?filter%5Bterritory%5D=USA&limit=200")
    UI.user_error!("price points GET #{code}: #{pp.inspect[0,200]}") unless code == 200
    points = pp["data"] || []
    free = points.find { |p| (p.dig("attributes", "customerPrice") || "x").to_f == 0.0 }
    UI.user_error!("no $0 price point found (#{points.size} points)") unless free
    UI.message "free price point id=#{free['id']}"

    # 2) Create the price schedule: base USA, manual price = free point
    body = {
      data: {
        type: "appPriceSchedules",
        relationships: {
          app: { data: { type: "apps", id: app.id } },
          baseTerritory: { data: { type: "territories", id: "USA" } },
          manualPrices: { data: [{ type: "appPrices", id: "${price1}" }] },
        },
      },
      included: [{
        type: "appPrices", id: "${price1}",
        attributes: { startDate: nil },
        relationships: {
          appPricePoint: { data: { type: "appPricePoints", id: free["id"] } },
          territory: { data: { type: "territories", id: "USA" } },
        },
      }],
    }
    # What's in the existing schedule?
    mc, mp = asc_raw(:get, "v1/appPriceSchedules/#{app.id}/manualPrices?include=appPricePoint&limit=200")
    prices = (mp["data"] || [])
    UI.message "existing manualPrices GET #{mc}: count=#{prices.size}"
    bc, bt = asc_raw(:get, "v1/appPriceSchedules/#{app.id}/baseTerritory")
    UI.message "baseTerritory GET #{bc}: #{(bt.dig('data','id') rescue bt.inspect[0,120])}"

    if prices.any?
      UI.success "Price schedule already has #{prices.size} price(s) — pricing is set."
      next
    end

    # POST replaces the schedule (create-or-replace per ASC API).
    code, resp = asc_raw(:post, "v1/appPriceSchedules", body)
    if [200, 201].include?(code)
      UI.success "FREE pricing set (appPriceSchedule created)"
    else
      UI.error "price schedule POST #{code}: #{resp.inspect[0,600]}"
    end
  end

  desc "Write App Privacy data usages directly (phone number + contacts) and publish."
  lane :asc_privacy_set do
    app = asc_connect
    # Apple enum IDs (stable strings used as resource ids)
    categories = %w[PHONE_NUMBER CONTACTS]
    purpose     = "APP_FUNCTIONALITY"
    protection  = "DATA_LINKED_TO_YOU"   # linked, not used for tracking

    posted = 0
    categories.each do |cat|
      body = {
        data: {
          type: "appDataUsages",
          relationships: {
            app:        { data: { type: "apps", id: app.id } },
            category:   { data: { type: "appDataUsageCategories", id: cat } },
            purpose:    { data: { type: "appDataUsagePurposes", id: purpose } },
            dataProtection: { data: { type: "appDataUsageDataProtections", id: protection } },
          },
        },
      }
      code, resp = asc_raw(:post, "v1/appDataUsages", body)
      if [200, 201].include?(code)
        UI.success "posted data usage #{cat}/#{purpose}/#{protection}"
        posted += 1
      else
        UI.important "POST #{cat} -> #{code}: #{resp.inspect[0,260]}"
      end
    end

    # Publish the privacy answers
    %w[
      v1/apps/#{app.id}/relationships/appDataUsagesPublishState
      v1/appDataUsagesPublishStates
    ].each do |path|
      pubbody = {
        data: {
          type: "appDataUsagesPublishStates",
          id: app.id,
          attributes: { published: true },
        },
      }
      code, resp = asc_raw(:patch, "v1/appDataUsagesPublishStates/#{app.id}", pubbody)
      UI.message "PATCH publishState -> #{code}: #{resp.inspect[0,200]}"
      break
    end
    UI.message "posted=#{posted}"
  end

  desc "Discover the App Privacy endpoint names from the app's relationship list."
  lane :asc_privacy do
    app = asc_connect
    # The app's full relationship set tells us the exact privacy path names.
    # Probe the documented privacy paths directly (collection + publish state).
    [
      "v1/apps/#{app.id}/appDataUsages?limit=5",
      "v1/apps/#{app.id}/dataUsagePublishState",
      "v1/apps/#{app.id}/appDataUsagesPublishState",
      "v1/dataUsagePublishStates?filter%5Bapp%5D=#{app.id}",
    ].each do |path|
      c, b = asc_raw(:get, path)
      UI.message "GET #{path.split('?').first} -> #{c} : #{b.inspect[0,180]}"
    end
  end

  desc "Probe App Privacy (data usage) categories + purposes + grants."
  lane :asc_priv_probe do
    app = asc_connect
    c = Spaceship::ConnectAPI
    begin
      cats = c.get_app_data_usage_categories(includes: nil, limit: 200).to_models
      UI.message "CATEGORIES (#{cats.size}):"
      cats.each { |x| UI.message "  cat #{x.id}" }
    rescue => e
      UI.error "categories: #{e.class} #{e.message[0,160]}"
    end
    begin
      purp = c.get_app_data_usage_purposes(includes: nil, limit: 200).to_models
      UI.message "PURPOSES (#{purp.size}):"
      purp.each { |x| UI.message "  purpose #{x.id}" }
    rescue => e
      UI.error "purposes: #{e.class} #{e.message[0,160]}"
    end
    begin
      st = c.get_app_data_usages_publish_state(app_id: app.id)
      m = st.to_models.first rescue nil
      UI.message "PUBLISH_STATE published=#{m&.published rescue '?'}"
    rescue => e
      UI.important "publish_state err: #{e.class} #{e.message[0,90]}"
    end
    begin
      us = c.get_app_data_usages(app_id: app.id, includes: nil, limit: 200).to_models
      UI.message "EXISTING data usages: #{us.size}"
    rescue => e
      UI.important "data_usages err: #{e.class} #{e.message[0,90]}"
    end
  end

  desc "Declare App Privacy: 'Data Not Collected' (publishes the privacy answers)."
  lane :asc_priv_none do
    app = asc_connect
    c = Spaceship::ConnectAPI
    # Remove any existing usages, then set the 'not collected' grant and publish.
    begin
      existing = c.get_app_data_usages(app_id: app.id, includes: nil, limit: 200).to_models
      existing.each { |u| c.delete_app_data_usage(app_data_usage_id: u.id) rescue nil }
      UI.message "cleared #{existing.size} existing usages"
    rescue => e
      UI.important "clear err: #{e.message[0,90]}"
    end
    # "DATA_NOT_COLLECTED" grant: post a usage with the special category.
    begin
      c.post_app_data_usage(app_id: app.id, app_data_usage_category_id: nil,
                            app_data_usage_protection_id: nil, app_data_usage_purpose_id: nil,
                            app_data_usage_data_protection_id: "DATA_NOT_COLLECTED")
      UI.success "posted DATA_NOT_COLLECTED"
    rescue => e
      UI.important "post not-collected err: #{e.class} #{e.message[0,120]}"
    end
    begin
      c.patch_app_data_usages_publish_state(app_id: app.id, published: true)
      UI.success "PUBLISHED app privacy"
    rescue => e
      UI.error "publish err: #{e.class} #{e.message[0,160]}"
    end
  end

  desc "Set the age-rating declaration to all-clear (4+), auto-resolving STRING vs BOOLEAN per field."
  lane :asc_agerating do
    app = asc_connect
    info = app.fetch_edit_app_info
    decl = info.fetch_age_rating_declaration
    UI.user_error!("no age rating declaration") unless decl

    string_fields = %w[
      alcoholTobaccoOrDrugUseOrReferences contests gamblingSimulated
      medicalOrTreatmentInformation profanityOrCrudeHumor
      sexualContentGraphicAndNudity sexualContentOrNudity horrorOrFearThemes
      matureOrSuggestiveThemes violenceCartoonOrFantasy violenceRealistic
      violenceRealisticProlongedGraphicOrSadistic gunsOrOtherWeapons
    ]
    bool_fields = %w[
      gambling unrestrictedWebAccess lootBox messagingAndChat
      healthOrWellnessTopics userGeneratedContent advertising
      parentalControls ageAssurance
    ]
    attrs = {}
    string_fields.each { |f| attrs[f.to_sym] = "NONE" }
    bool_fields.each   { |f| attrs[f.to_sym] = false }

    ok = false
    20.times do |i|
      begin
        decl.update(attributes: attrs)
        UI.success("Age rating set on attempt #{i + 1}")
        ok = true
        break
      rescue => e
        msg = e.message.to_s
        m = msg.match(/attribute '([A-Za-z]+)'.*?Expected a (BOOLEAN|STRING)/m)
        if m
          field = m[1].to_sym
          want = m[2]
          attrs[field] = (want == "BOOLEAN" ? false : "NONE")
          UI.message("  fix #{field} -> #{want}")
        else
          UI.error("Unparseable: #{msg[0,200]}")
          raise
        end
      end
    end
    UI.user_error!("age rating: gave up after 20 attempts") unless ok
  end

  desc "Set name/subtitle on the editable App Info localization (bypass deliver)."
  lane :asc_text do
    app = asc_connect
    info = app.fetch_edit_app_info
    locs = info.get_app_info_localizations
    UI.message "app_info locales: " + locs.map(&:locale).join(", ")
    loc = locs.find { |l| l.locale == "en-US" } || locs.first
    UI.message "before: name=#{loc.name.inspect} subtitle=#{loc.subtitle.inspect}"
    new_name = ENV["SLIDE_APP_NAME"] || "Slide - Fast Video Calls"
    loc.update(attributes: { name: new_name, subtitle: "Calls that beat bad internet" })
    UI.success "set name (#{new_name}) + subtitle (28 chars) on #{loc.locale}"
  end

  desc "Probe pricing + privacy API surface."
  lane :asc_probe2 do
    app = asc_connect
    client = Spaceship::ConnectAPI
    UI.message "ConnectAPI methods (price/privacy/territory/availab): " +
      client.methods.map(&:to_s).grep(/price|privacy|territor|availab|data_usage|datausage/i).sort.join(", ")
    # Try direct GETs against the documented endpoints
    [
      "apps/#{app.id}/appPriceSchedule",
      "apps/#{app.id}/appAvailabilityV2",
      "apps/#{app.id}/appPricePoints?limit=3",
      "apps/#{app.id}/appInfos",
    ].each do |url|
      begin
        r = client.get(url: url)
        n = (r.to_models.size rescue (r.respond_to?(:count) ? r.count : "?"))
        UI.success "GET #{url} -> ok (#{n})"
      rescue => e
        UI.important "GET #{url} -> #{e.class}: #{e.message[0,90]}"
      end
    end
    # Price points for free tier
    begin
      r = client.get(url: "apps/#{app.id}/appPricePoints", params: { "filter[territory]" => "USA", limit: 200 })
      pts = r.to_models
      free = pts.find { |p| (p.customer_price.to_f rescue 1.0) == 0.0 }
      UI.message "pricePoints=#{pts.size} freePoint=#{free&.id}"
    rescue => e
      UI.important "pricePoints err: #{e.class} #{e.message[0,100]}"
    end
  end

  desc "Authoritative: is the app actually submitted for review?"
  lane :asc_state do
    app = asc_connect
    v = app.get_edit_app_store_version || app.get_latest_app_store_version
    UI.header "VERSION #{v&.version_string} state=#{v&.app_store_state}"
    begin
      ip = app.get_in_progress_review_submission
      UI.message "in_progress_review_submission: #{ip ? "present id=#{ip.id} state=#{ip.state rescue '?'}" : 'NONE'}"
    rescue => e
      UI.message "in_progress review: #{e.class} #{e.message[0,80]}"
    end
    begin
      subs = app.get_review_submissions
      UI.message "review_submissions: #{subs.size}"
      subs.each { |s| UI.message("  - id=#{s.id} state=#{s.state rescue '?'} platform=#{s.platform rescue '?'}") }
    rescue => e
      UI.message "review_submissions: #{e.class} #{e.message[0,80]}"
    end
  end

  # Return [{id,name,internal,publicLink}] for the app's beta groups (raw REST).
  def tf_groups(app)
    code, body = asc_raw(:get, "v1/apps/#{app.id}/betaGroups?limit=200")
    UI.user_error!("betaGroups GET #{code}: #{body.inspect[0,160]}") unless code == 200
    (body["data"] || []).map do |g|
      { "id" => g["id"], "name" => g.dig("attributes","name"),
        "internal" => g.dig("attributes","isInternalGroup"),
        "publicLink" => g.dig("attributes","publicLink") }
    end
  end

  desc "Show TestFlight groups + testers."
  lane :tf_status do
    app = asc_connect
    groups = tf_groups(app)
    UI.header "Beta groups: #{groups.size}"
    groups.each do |g|
      UI.message "  - '#{g['name']}' internal=#{g['internal']} public_link=#{g['publicLink'] || 'none'} id=#{g['id']}"
    end
    code, body = asc_raw(:get, "v1/apps/#{app.id}/betaTesters?limit=100")
    testers = body["data"] || []
    UI.message "Testers: #{testers.size}"
    testers.each { |t| UI.message "  - #{t.dig('attributes','email')} (#{t.dig('attributes','state')})" }
  end

  desc "Show the latest build's TestFlight readiness (processing + beta review + groups)."
  lane :tf_build_state do
    app = asc_connect
    code, body = asc_raw(:get, "v1/builds?filter%5Bapp%5D=#{app.id}&sort=-version&limit=3&include=betaGroups")
    (body["data"] || []).each do |b|
      a = b["attributes"]
      grp_ids = (b.dig("relationships","betaGroups","data") || []).map { |g| g["id"] }
      UI.message "build #{a['version']} processing=#{a['processingState']} expired=#{a['expired']} groups=#{grp_ids.size}"
      # Beta app review state
      rc, rb = asc_raw(:get, "v1/builds/#{b['id']}/betaAppReviewSubmission")
      st = rb.dig("data","attributes","betaReviewState") rescue nil
      UI.message "   betaReviewState=#{st || 'NONE (not submitted for beta review)'}"
    end
  end

  desc "Fill the TestFlight beta metadata (description + feedback email + review contact) required for external beta review."
  lane :tf_beta_meta do
    app = asc_connect
    desc_text = "Slide is a simple phone-first video calling app. Tap a contact to start a 1:1 or group video/audio call. Test calls, group calls, and audio routing to Bluetooth/wired earbuds."
    feedback_email = ENV["TF_FEEDBACK_EMAIL"] || ENV["FASTLANE_APPLE_ID"] || "viraat@exla.ai"

    # 1) Beta app localization (description + feedback email + marketing/privacy URLs)
    code, body = asc_raw(:get, "v1/apps/#{app.id}/betaAppLocalizations")
    locs = body["data"] || []
    loc = locs.find { |l| l.dig("attributes","locale") == "en-US" } || locs.first
    attrs = { description: desc_text, feedbackEmail: feedback_email }
    if loc
      c,b = asc_raw(:patch, "v1/betaAppLocalizations/#{loc['id']}",
        { data: { type: "betaAppLocalizations", id: loc["id"], attributes: attrs } })
      UI.message "beta localization PATCH #{c}"
    else
      c,b = asc_raw(:post, "v1/betaAppLocalizations",
        { data: { type: "betaAppLocalizations",
                  attributes: attrs.merge(locale: "en-US"),
                  relationships: { app: { data: { type: "apps", id: app.id } } } } })
      UI.message "beta localization POST #{c}: #{b.inspect[0,120]}"
    end

    # 2) Beta app review detail (contact info + demo account / notes)
    contact_first = ENV["TF_CONTACT_FIRST"] || "Viraat"
    contact_last  = ENV["TF_CONTACT_LAST"]  || "Das"
    contact_phone = ENV["TF_CONTACT_PHONE"] || "+1 415 555 0137"
    rdetail = { contactFirstName: contact_first, contactLastName: contact_last,
                contactEmail: feedback_email, contactPhone: contact_phone,
                demoAccountRequired: false, demoAccountName: "", demoAccountPassword: "",
                notes: "Phone-first video calling. No login wall for testing; the app uses phone-number OTP — use any number, the dev build accepts the echoed code." }
    rc, rbody = asc_raw(:get, "v1/apps/#{app.id}/betaAppReviewDetail")
    rid = rbody.dig("data","id")
    if rid
      c,b = asc_raw(:patch, "v1/betaAppReviewDetails/#{rid}",
        { data: { type: "betaAppReviewDetails", id: rid, attributes: rdetail } })
      UI.message "beta review detail PATCH #{c}"
    else
      c,b = asc_raw(:post, "v1/betaAppReviewDetails",
        { data: { type: "betaAppReviewDetails", attributes: rdetail,
                  relationships: { app: { data: { type: "apps", id: app.id } } } } })
      UI.message "beta review detail POST #{c}: #{b.inspect[0,120]}"
    end
    UI.success "Beta metadata set (description + feedback #{feedback_email} + review contact)."
  end

  desc "Submit the latest build for TestFlight Beta App Review (needed for EXTERNAL testers)."
  lane :tf_beta_submit do
    app = asc_connect
    build = Spaceship::ConnectAPI::Build.all(app_id: app.id, sort: "-version", limit: 1).first
    UI.user_error!("no build") unless build
    code, body = asc_raw(:post, "v1/betaAppReviewSubmissions", {
      data: { type: "betaAppReviewSubmissions",
              relationships: { build: { data: { type: "builds", id: build.id } } } } })
    if (200..299).include?(code)
      UI.success "Submitted build #{build.version} for Beta App Review."
    else
      UI.important "beta submit #{code}: #{body.inspect[0,200]}"
    end
  end

  desc "Enable a PUBLIC TestFlight link on an external group so anyone can join. Set TF_GROUP (default 'Friends')."
  lane :tf_public_link do
    app = asc_connect
    name = ENV["TF_GROUP"] || "Friends"
    groups = Spaceship::ConnectAPI::BetaGroup.all(app_id: app.id)
    grp = groups.find { |g| g.name == name && !g.is_internal_group }
    if grp.nil?
      # Create an external group (external groups support public links).
      code, body = asc_raw(:post, "v1/betaGroups", {
        data: { type: "betaGroups",
                attributes: { name: name, publicLinkEnabled: true, publicLinkLimitEnabled: false },
                relationships: { app: { data: { type: "apps", id: app.id } } } } })
      UI.user_error!("create group #{code}: #{body.inspect[0,200]}") unless (200..299).include?(code)
      gid = body.dig("data","id")
      UI.success "Created external group '#{name}' (#{gid})"
    else
      gid = grp.id
      asc_raw(:patch, "v1/betaGroups/#{gid}", {
        data: { type: "betaGroups", id: gid, attributes: { publicLinkEnabled: true } } })
      UI.success "Enabled public link on existing group '#{name}' (#{gid})"
    end
    # Attach the latest build to the group so the link actually serves something.
    build = Spaceship::ConnectAPI::Build.all(app_id: app.id, sort: "-version", limit: 1).first
    if build
      asc_raw(:post, "v1/betaGroups/#{gid}/relationships/builds",
              { data: [{ type: "builds", id: build.id }] })
      UI.message "Attached build #{build.version} to '#{name}'"
    end
    code, body = asc_raw(:get, "v1/betaGroups/#{gid}")
    link = body.dig("data","attributes","publicLink")
    UI.header "PUBLIC TESTFLIGHT LINK: #{link || '(provisioning — re-run tf_status in a minute)'}"
  end

  desc "Invite external testers by email. Set TF_EMAILS='a@x.com,b@y.com' and optional TF_GROUP."
  lane :tf_invite do
    app = asc_connect
    emails = (ENV["TF_EMAILS"] || "").split(",").map(&:strip).reject(&:empty?)
    UI.user_error!("Set TF_EMAILS='a@x.com,b@y.com'") if emails.empty?
    name = ENV["TF_GROUP"] || "Friends"
    grp = tf_groups(app).find { |g| g["name"] == name }
    if grp.nil?
      code, body = asc_raw(:post, "v1/betaGroups", {
        data: { type: "betaGroups", attributes: { name: name },
                relationships: { app: { data: { type: "apps", id: app.id } } } } })
      UI.user_error!("create group #{code}: #{body.inspect[0,200]}") unless (200..299).include?(code)
      gid = body.dig("data","id")
    else
      gid = grp["id"]
    end
    # Attach latest build so invited testers have something to install.
    build = Spaceship::ConnectAPI::Build.all(app_id: app.id, sort: "-version", limit: 1).first
    asc_raw(:post, "v1/betaGroups/#{gid}/relationships/builds",
            { data: [{ type: "builds", id: build.id }] }) if build
    emails.each do |em|
      code, body = asc_raw(:post, "v1/betaTesters", {
        data: { type: "betaTesters",
                attributes: { email: em, firstName: em.split("@").first, lastName: "Tester" },
                relationships: { betaGroups: { data: [{ type: "betaGroups", id: gid }] } } } })
      if (200..299).include?(code)
        UI.success "Invited #{em}"
      else
        UI.important "#{em} -> #{code}: #{body.inspect[0,140]}"
      end
    end
    UI.header "Invited #{emails.size} tester(s) to '#{name}'. They get an email + can install via TestFlight."
  end

  desc "Cancel the in-progress review submission so the version becomes editable again."
  lane :asc_cancel_review do
    app = asc_connect
    code, body = asc_raw(:get, "v1/apps/#{app.id}/reviewSubmissions?limit=50")
    subs = body["data"] || []
    UI.message "found #{subs.size} review submission(s)"
    subs.each do |s|
      st = s.dig("attributes", "state")
      UI.message "  #{s['id']} state=#{st}"
      next unless %w[WAITING_FOR_REVIEW IN_REVIEW READY_FOR_REVIEW].include?(st)
      pc, pr = asc_raw(:patch, "v1/reviewSubmissions/#{s['id']}",
        { data: { type: "reviewSubmissions", id: s["id"], attributes: { canceled: true } } })
      if (200..299).include?(pc)
        UI.success "  canceled #{s['id']} (#{pc})"
      else
        UI.important "  cancel PATCH #{s['id']} -> #{pc}: #{pr.inspect[0,200]}"
      end
    end
  end

  desc "Poll build processing, then attach the newest build to the editable 1.0.0 version."
  lane :attach_latest_build do
    app = asc_connect
    target_version = ENV["SLIDE_TARGET_BUILD"] # optional specific build number
    build = nil
    40.times do |i|
      builds = Spaceship::ConnectAPI::Build.all(app_id: app.id, sort: "-version", limit: 5)
      build = if target_version
                builds.find { |b| b.version.to_s == target_version.to_s }
              else
                builds.first
              end
      st = build&.processing_state
      UI.message("[#{i}] build #{build&.version} state=#{st}")
      break if st == "VALID"
      sleep(15)
    end
    UI.user_error!("No build became VALID") unless build && build.processing_state == "VALID"

    # Clear export compliance on the build.
    begin
      build.update(attributes: { usesNonExemptEncryption: false })
      UI.success("Export compliance cleared on build #{build.version}")
    rescue => e
      UI.important("Compliance note: #{e.message}")
    end

    v = app.get_edit_app_store_version
    UI.user_error!("No editable version to attach to (it may be locked in review)") unless v
    v.select_build(build_id: build.id)
    UI.success("Attached build #{build.version} to version #{v.version_string}")
  end

end
