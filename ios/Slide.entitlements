<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Push Notifications capability. APNs environment is resolved at signing
	     time; "development" here is overridden to "production" for Release/
	     TestFlight builds via the per-config CODE_SIGN_ENTITLEMENTS in
	     project.yml. Requires the App ID (app.exla.slide) to have Push enabled
	     in the Apple Developer portal + an APNs key. -->
	<key>aps-environment</key>
	<string>development</string>
</dict>
</plist>
